{
  "name": "stateless-seal",
  "version": "0.4.0",
  "description": "Purpose-bound sealed tokens for JavaScript.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare.d.ts",
      "import": "./dist/cloudflare.js",
      "require": "./dist/cloudflare.cjs"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.js",
      "require": "./dist/testing.cjs"
    }
  },
  "files": [
    "dist",
    "SPEC.md",
    "SECURITY.md",
    "THREAT-MODEL.md",
    "TEST-VECTORS.md",
    "CHANGELOG.md",
    "docs",
    "examples",
    "test-vectors",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev:test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arfoux/stateless-seal.git"
  },
  "keywords": [
    "token",
    "sealed-token",
    "stateless",
    "encryption",
    "aes-gcm",
    "webcrypto",
    "purpose-bound",
    "session",
    "security"
  ],
  "author": "Fatih Farros",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/arfoux/stateless-seal/issues"
  },
  "homepage": "https://github.com/arfoux/stateless-seal#readme",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
